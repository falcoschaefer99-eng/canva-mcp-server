# Canva OAuth credentials (get from https://www.canva.com/developers/)
CANVA_CLIENT_ID=your_canva_client_id_here
CANVA_CLIENT_SECRET=your_canva_client_secret_here
CANVA_REDIRECT_URI=http://127.0.0.1:8001/auth/callback

# Optional: secure MCP endpoints with a Bearer token
MCP_AUTH_TOKEN=

# Optional: allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173
